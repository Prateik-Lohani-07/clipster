{
	"name": "Clipster",
	"description": "Lightweight, easy-to-use clipboard. Right from your browser.",
	"version": "1.1",
	"manifest_version": 3,
	"action": {
		"default_popup": "index.html",
		"default_icon": "logo.png",
		"default_title": "Open Clipboard"
	},
	"permissions": [
		"sidePanel"
	],
	"side_panel": {
		"default_path": "index.html"
	}
}